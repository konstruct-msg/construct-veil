# ── Required ─────────────────────────────────────────────────────────────────

# The primary domain pointing at this VPS. ACME certificate is issued for this
# name; clients pin its SPKI; relay's --cert path uses this as the live/<name>
# directory key. veil-front clients use this name as their TLS SNI.
DOMAIN=api.divany-kresla.uk

# Additional SAN names included in the same cert, comma-separated. Each must
# also have an A/AAAA record pointing at this VPS (required for ACME http-01
# challenge to pass). Leave empty if only $DOMAIN is needed.
#   Example: EXTRA_DOMAINS=divany-kresla.uk,www.divany-kresla.uk
EXTRA_DOMAINS=divany-kresla.uk

# Contact email for Let's Encrypt expiry notices.
EMAIL=hello@divany-kresla.uk

# Construct gRPC backend the tunnel forwards to (host:port).
# This relay is a remote FRONT (e.g. in RU): the backend is the public Construct
# endpoint reached over TLS (Traefik :443 → envoy h2c). The compose forces
# --backend-tls and --backend-sni, so point this at the public host:443.
#   BACKEND=ams.konstruct.cc:443  /  BACKEND_SNI=ams.konstruct.cc (default)
# Only use host.docker.internal:50051 (and drop --backend-tls) if the backend is
# truly co-located on THIS VPS — not the case for a front relay.
BACKEND=ams.konstruct.cc:443

# ── Optional ─────────────────────────────────────────────────────────────────

# Default ticket validity (days). 60d aligns with Let's Encrypt 60-day rotation.
TICKET_DAYS=60

# tracing-subscriber EnvFilter — set to "debug" for verbose relay logs.
RUST_LOG=info
